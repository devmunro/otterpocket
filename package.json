{
  "name": "otterpocket",
  "version": "1.0.0",
  "description": "A small, friendly React state library with guided helper methods.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./core": {
      "types": "./dist/src/core.d.ts",
      "import": "./dist/src/core.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node dist/tests/core.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devmunro/otterpocket.git"
  },
  "keywords": [
    "react",
    "state",
    "state-management",
    "store",
    "persist",
    "selectors",
    "zustand-alternative",
    "otterpocket"
  ],
  "author": "David Munro",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/devmunro/otterpocket/issues"
  },
  "homepage": "https://github.com/devmunro/otterpocket#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "typescript": "^5.9.2"
  }
}
